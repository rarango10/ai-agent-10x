# Copia a apps/web/.env.local y rellena los valores (ver README paso 5).
# Next.js solo carga .env* desde apps/web.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Postgres for LangGraph checkpoints (Project Settings → Database → Connect).
# Use Session pooler (IPv4) if direct db.* fails on your network: user postgres.[project-ref], host aws-*-[region].pooler.supabase.com, port 5432.
# If Node reports SELF_SIGNED_CERT_IN_CHAIN, append either uselibpqcompat=true (with sslmode=require) or sslmode=no-verify for local dev.
# Example: ...pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true
# If the URL contains &, wrap the whole value in double quotes (required for `source .env.local` in bash).
# The agent appends uselibpqcompat=true for Node/pg unless DATABASE_SSL_VERIFY_STRICT=true, so the same URI as psql often suffices.
DATABASE_URL=
# DATABASE_SSL_VERIFY_STRICT=true

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key
# Modelo OpenAI-compatible (https://openrouter.ai/models). Ejemplo gratuito:
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# Por defecto en código: qwen/qwen3.6-plus (de pago en OpenRouter).

# --- Tareas programadas (cron) — configuración típica (README, “paso 2”) ---
# 1) Genera un valor aleatorio fuerte y úsalo solo en servidor (nunca en el cliente):
#    openssl rand -hex 32
# 2) Pega ese valor en CRON_SECRET (este archivo es plantilla; el real va en apps/web/.env.local).
# 3) Tu programador (Supabase pg_cron + pg_net, Vercel Cron, etc.) debe hacer:
#      POST https://TU_DOMINIO/api/cron/execute
#    con cabecera:
#      x-cron-secret: <exactamente el mismo valor que CRON_SECRET>
#    Cuerpo puede ser {} (JSON vacío).
# Si CRON_SECRET está vacío o no coincide la cabecera, /api/cron/execute responde 503 o 401.
# Ejemplo de forma (no uses este valor en producción; genera el tuyo):
CRON_SECRET=7f3e9a1b4c8d2e6f0a5b9c3d7e1f4a8b6c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f

# Telegram — necesario si quieres recibir por el bot el resultado de cada ejecución programada
# (además del chat normal). Sin esto el cron sigue ejecutando el agente, pero no hay notificación.
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHI_jklMNOpqrsTUVwxyz
# Secreto que Telegram envía en x-telegram-bot-api-secret-token; debe coincidir al registrar el webhook.
# TELEGRAM_WEBHOOK_SECRET=reemplaza_con_otro_secreto_aleatorio
# Origen HTTPS público del webhook si visitas /api/telegram/setup vía túnel (p. ej. ngrok)
# TELEGRAM_WEBHOOK_BASE_URL=https://your-subdomain.ngrok-free.app

# Cifrado AES-256-GCM de tokens OAuth (GitHub). Generar: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=your_64_hex_chars_here

# GitHub OAuth App (Settings → Developer settings → OAuth Apps)
# Authorization callback URL: {NEXT_PUBLIC_APP_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# URL pública de la app (sin barra final), ej. http://localhost:3000 o https://tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: orígenes extra permitidos en dev (coma-separados); ngrok ya incluye *.ngrok-free.app
# NEXT_ALLOWED_DEV_ORIGINS=

# Herramienta Bash (ejecuta en el host Node del backend; en la nube es el servidor, no el Mac del usuario).
# Apagado global del despliegue (1 = no se registra la tool ni se ejecuta subprocess). El toggle por usuario sigue en UI → user_tool_settings (tool_id Bash).
# BASH_TOOL_DISABLED=1
# Directorio de trabajo por defecto si no hay default_cwd / terminals en user_tool_settings (Bash)
# BASH_TOOL_DEFAULT_CWD=/path/to/project
# Timeout en ms (por defecto 60000)
# BASH_TOOL_TIMEOUT_MS=60000
# Tope de caracteres combinados stdout+stderr (por defecto 50000)
# BASH_TOOL_MAX_OUTPUT_CHARS=50000

# --- Langfuse (observabilidad / tracing) ---
# Ejecutando Langfuse local: docker compose up en el repo de langfuse, puerto 3001.
# Crea un proyecto en http://localhost:3001 → Settings → API Keys.
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=http://localhost:3001
# LangChain >=0.3 ejecuta callbacks en background; en serverless hay que forzar modo síncrono.
LANGCHAIN_CALLBACKS_BACKGROUND=false

# Herramientas read_file / write_file / edit_file (mismo workspace que Bash: terminals/default_cwd).
# Apagado global (1 = no se registran las tres tools).
# FILE_TOOLS_DISABLED=1
# Líneas máximas por defecto al leer sin limit explícito (por defecto 500)
# FILE_TOOLS_MAX_READ_LINES=500
# Tope de caracteres del fragmento en la respuesta JSON de read_file (por defecto 100000)
# FILE_TOOLS_MAX_OUTPUT_CHARS=100000
# Tamaño máximo de archivo a leer/editar en bytes (por defecto 5 MiB)
# FILE_TOOLS_MAX_FILE_BYTES=5242880
